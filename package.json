{
  "name": "@ngx-layout/source",
  "description": "ngx-layout",
  "version": "22.0.0",
  "homepage": "https://github.com/ngbracket/ngx-layout",
  "bugs": "https://github.com/ngbracket/ngx-layout/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngbracket/ngx-layout.git"
  },
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >= 24.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve updated-demo",
    "build": "ng build @ngbracket/ngx-layout",
    "demo:serve": "ng serve updated-demo",
    "docs": "cd projects/apps/docs/documentation && npx docusaurus start --port 3000",
    "stamp": "ts-node tools/package-tools/version-placeholders.ts --module=commonjs",
    "build:demo-app": "ng build updated-demo --configuration=production",
    "build:docs": "cd projects/apps/docs/documentation && npx docusaurus build",
    "build:universal-demo-app": "ng build universal-demo-app --configuration=production",
    "serve:universal-demo-app": "ng serve universal-demo-app",
    "serve:updated-demo-static": "ng build updated-demo --configuration=production && npx serve dist/projects/apps/updated-demo/browser -s",
    "test": "ng test @ngbracket/ngx-layout",
    "test:ssr": "webpack --config test/webpack-spec-ssr-bundle.js && jasmine --config=test/jasmine-ssr.json",
    "lint": "stylelint projects/libs/**/*.scss --config=stylelint-config.json",
    "release": "npm run build && npm run stamp",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "serve:ssr:universal-demo-app": "node dist/universal-demo-app/server/server.mjs",
    "format": "prettier --write \"**/*.{ts,js,json,html,scss,css}\" --ignore-path .gitignore",
    "format:write": "prettier --write \"**/*.{ts,js,json,html,scss,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,js,json,html,scss,css}\" --ignore-path .gitignore",
    "update": "ng update",
    "help": "ng help"
  },
  "private": true,
  "requiredAngularVersion": ">=22.0.0",
  "dependencies": {
    "@angular/animations": "22.0.0-rc.3",
    "@angular/common": "22.0.0-rc.3",
    "@angular/compiler": "22.0.0-rc.3",
    "@angular/core": "22.0.0-rc.3",
    "@angular/forms": "22.0.0-rc.3",
    "@angular/material": "22.0.0-rc.3",
    "@angular/platform-browser": "22.0.0-rc.3",
    "@angular/platform-browser-dynamic": "22.0.0-rc.3",
    "@angular/platform-server": "22.0.0-rc.3",
    "@angular/router": "22.0.0-rc.3",
    "@angular/ssr": "22.0.0-rc.3",
    "@docusaurus/preset-classic": "3.8.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "22.0.0-rc.3",
    "@angular-devkit/schematics": "22.0.0-rc.3",
    "@angular/build": "22.0.0-rc.3",
    "@angular/cdk": "22.0.0-rc.3",
    "@angular/cli": "22.0.0-rc.3",
    "@angular/compiler-cli": "22.0.0-rc.3",
    "@angular/language-service": "22.0.0-rc.3",
    "@docusaurus/module-type-aliases": "3.4.0",
    "@docusaurus/tsconfig": "3.8.1",
    "@docusaurus/types": "3.8.1",
    "@eslint/js": "^9.39.1",
    "@ngtools/webpack": "22.0.0-rc.3",
    "@schematics/angular": "22.0.0-rc.3",
    "@types/express": "^4.17.25",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.19.25",
    "@typescript-eslint/utils": "8.60.0",
    "angular-eslint": "21.4.0",
    "autoprefixer": "^10.4.22",
    "conventional-changelog-cli": "^4.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.5",
    "istanbul-lib-instrument": "^6.0.3",
    "minimatch": "^9.0.5",
    "ng-packagr": "22.0.0-rc.0",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "postcss-url": "~10.1.3",
    "prettier": "^3.6.2",
    "stylelint": "^15.11.0",
    "ts-node": "^10.9.2",
    "tsutils": "^3.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "^4.1.8",
    "webpack": "5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "overrides": {
    "webpack": "5.95.0",
    "browser-sync-client": "2.29.3"
  },
