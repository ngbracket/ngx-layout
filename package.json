    "@angular/platform-server": "22.0.1",
    "@angular/router": "22.0.1",
    "@angular/ssr": "22.0.1",
    "@docusaurus/preset-classic": "^3.10.0",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "express": "^4.21.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
