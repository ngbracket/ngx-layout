    "@docusaurus/types": "^3.8.1",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.25",
    "angular-eslint": "22.0.0",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-angular": "^8.3.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.5",
    "jsdom": "^29.1.1",
    "ng-packagr": "22.0.0",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
