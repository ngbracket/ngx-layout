{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../out-tsc/spec",
    "types": ["vitest/globals"],
    "moduleResolution": "bundler"
  },
  "include": [
    "**/*.spec.ts",
    "**/*.d.ts",
    "**/testing/**/*.ts",
    "test-setup.ts",
    "test-providers.ssr.ts"
  ],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
