{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../out-tsc/lib",
    "declaration": true,
    "declarationMap": false,
    "inlineSources": true,
    "moduleResolution": "bundler"
  },
  "exclude": ["test.ts", "**/*.spec.ts", "**/testing/**/*.ts"],
  "include": ["**/*.ts"],
  "angularCompilerOptions": {
    "extendedDiagnostics": {
      "checks": {
        "nullishCoalescingNotNullable": "suppress",
        "optionalChainNotNullable": "suppress"
      }
    }
  }
}
